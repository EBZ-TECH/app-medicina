# =============================================================================
# USO: copia este archivo a ".env" y rellena los valores.
#       cp .env.example .env   (Mac/Linux)
#       copy .env.example .env (Windows cmd)
#
# Guía paso a paso: CONFIGURACION.md (misma carpeta backend/)
# =============================================================================
#
# ESTE ARCHIVO (.env) = SOLO TU PC. No subas .env a Git (ya está en .gitignore).
#
# RENDER (nube): las MISMAS variables en el panel del servicio → Environment.
# SUPABASE (Edge Secrets): SOLO la variable API_UPSTREAM (URL de Render).
# =============================================================================

PORT=3000
CORS_ORIGIN=*

# Obligatorio: cadena larga y aleatoria (misma en Render en producción).
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_secreta

# Obligatorio: URI PostgreSQL de Supabase (Project Settings → Database → Connect).
# Si la contraseña tiene caracteres especiales (# @ : / etc.), codifícalos en la URL:
#   # → %23    @ → %40    : → %3A (solo dentro de usuario/contraseña)
# Ejemplo (ficticio): postgresql://postgres:miPass%231@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD_CODIFICADA@db.TU_REF.supabase.co:5432/postgres

# Opcional
# DATABASE_SSL=false
# UPLOADS_DIR=C:\ruta\absoluta\uploads
