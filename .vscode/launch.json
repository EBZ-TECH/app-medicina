      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:3000"
      ]
    },
    {
      "name": "AppMedicina (Chrome local API)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://localhost:3000"
      ],
      "deviceId": "chrome"
    }
  ]
}
